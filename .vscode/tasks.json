{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Iniciar servidor local (8080)",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/.vscode/dev-server.js"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Servidor pronto em http://localhost:8080"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
